<?xml version="1.0" encoding="utf-8"?>
<!--
  Wire the MediaTek IMS service as the default MMTel + RCS implementation.
  Without these overrides the strings are empty and PhoneGlobals never binds
  to com.mediatek.ims, so VoLTE registration never happens and outgoing
  voice calls fail with CM_SER_UNAVAILABLE on LTE-only networks.
-->
<resources>
    <string name="config_ims_mmtel_package" translatable="false">com.mediatek.ims</string>
    <string name="config_ims_rcs_package" translatable="false">com.mediatek.ims</string>
</resources>
